# Copy this file to `.env` (kept out of git) and fill in the values.
# Docker Compose reads `.env` automatically from the project root.

# Podcast RSS feed URL — powers the GET /api/podcast/latest endpoint, which
# returns the 3 most recent episodes. Read server-side only; never exposed to
# the browser. If left unset, the endpoint responds 503 and the rest of the
# site still works.
PODCAST_RSS_URL=

# Optional overrides (sensible defaults are baked into the image):
# PORT=3000
# HOST=0.0.0.0
