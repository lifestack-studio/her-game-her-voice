# Copy this file to `.env` (kept out of git) and fill in the values.
# Docker Compose reads `.env` automatically from the project root.

# Podcast RSS feed URL — powers the GET /api/podcast/latest endpoint, which
# returns the 3 most recent episodes. Read server-side only; never exposed to
# the browser. If left unset, the endpoint responds 503 and the rest of the
# site still works.
PODCAST_RSS_URL=

# --- TikTok latest-videos feed (Behind the Scenes page) ---------------------
# Powers GET /api/tiktok/latest. There are two ways to source videos.
# Only configure one path; the route uses the first available one.
#
# A) Lovable connector gateway (quickest, works on any host including Docker):
#    Connect the TikTok account in Lovable project settings, then copy the two
#    injected secrets into your self-hosted .env. Leave the direct-API
#    variables below unset. See TIKTOK_SETUP.md Path A.
LOVABLE_API_KEY=
TIKTOK_API_KEY=
#
# B) Direct TikTok Display API (no Lovable dependency, more setup):
#    Create a TikTok for Developers app with user.info.basic + video.list
#    scopes, register <your-domain>/api/tiktok/auth/callback as a redirect
#    URI, then run the OAuth flow once. See TIKTOK_SETUP.md Path B.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Obtained once via the built-in OAuth flow (/api/tiktok/auth/start?key=...).
TIKTOK_REFRESH_TOKEN=
# Gate for the one-time OAuth onboarding routes. Set to any long random string.
TIKTOK_ADMIN_TOKEN=
#
# If none of the above are set, the page falls back to its hardcoded clips.

# Optional overrides (sensible defaults are baked into the image):
# PORT=3000
# HOST=0.0.0.0
